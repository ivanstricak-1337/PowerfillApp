<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <EditText android:id="@+id/dayPrice" android:hint="Day Price €/kWh" android:inputType="numberDecimal"/>
    <EditText android:id="@+id/nightPrice" android:hint="Night Price €/kWh" android:inputType="numberDecimal"/>
    <EditText android:id="@+id/dayStart" android:hint="Day Start Hour" android:inputType="number"/>
    <EditText android:id="@+id/dayEnd" android:hint="Day End Hour" android:inputType="number"/>
    <EditText android:id="@+id/nightStart" android:hint="Night Start Hour" android:inputType="number"/>
    <EditText android:id="@+id/nightEnd" android:hint="Night End Hour" android:inputType="number"/>
    <Button android:id="@+id/saveBtn" android:text="Save"/>
</LinearLayout>
